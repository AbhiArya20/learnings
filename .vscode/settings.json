{
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    ".turbo": true,
    ".vscode": true,
    "yarn.lock": true,
    "turbo.json": true,
    "README.md": true,
    "package.json": true,
    ".npmrc": true,
    ".gitignore": true,
    "node_modules": true,
    "apps/frontend/.next": true,
    "apps/frontend/node_modules": true,
    "apps/frontend/components.json": true,
    "apps/frontend/eslint.config.mjs": true,
    "apps/frontend/next-env.d.ts": true,
    "apps/frontend/postcss.config.mjs": true,
    "apps/frontend/tailwind.config.ts": true,
    "apps/frontend/.gitignore": true,
    "packages": true,
    "apps/frontend/tsconfig.json": true,
    "apps/frontend/package.json": true
  },
  "hide-files.files": [
    ".turbo",
    ".vscode",
    "yarn.lock",
    "turbo.json",
    "README.md",
    "package.json",
    ".npmrc",
    ".gitignore",
    "node_modules",
    "apps/frontend/.next",
    "apps/frontend/node_modules",
    "apps/frontend/components.json",
    "apps/frontend/eslint.config.mjs",
    "apps/frontend/next-env.d.ts",
    "apps/frontend/postcss.config.mjs",
    "apps/frontend/tailwind.config.ts",
    "apps/frontend/.gitignore",
    "packages",
    "apps/frontend/tsconfig.json",
    "apps/frontend/package.json"
  ],
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#ab307e",
    "activityBar.background": "#ab307e",
    "activityBar.foreground": "#e7e7e7",
    "activityBar.inactiveForeground": "#e7e7e799",
    "activityBarBadge.background": "#25320e",
    "activityBarBadge.foreground": "#e7e7e7",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#ab307e",
    "statusBar.background": "#832561",
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#ab307e",
    "statusBarItem.remoteBackground": "#832561",
    "statusBarItem.remoteForeground": "#e7e7e7",
    "titleBar.activeBackground": "#832561",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#83256199",
    "titleBar.inactiveForeground": "#e7e7e799"
  },
  "peacock.color": "#832561",
  "editor.wordWrap": "on",
  "typescript.tsdk": "node_modules\\typescript\\lib"
}
