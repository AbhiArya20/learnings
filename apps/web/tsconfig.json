{
  "extends": "@learnings/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@learnings/ui/*": [
        "../../packages/ui/src/*"
      ]
    },
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
, "postcss.config.mjs"  ],
  "exclude": [
    "node_modules"
  ]
}